// ==========================================
// CẤU HÌNH KẾT NỐI
// ==========================================
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ==========================================
// ĐỊNH NGHĨA ENUM (Kiểu dữ liệu cố định)
// ==========================================
enum Role {
  ADMIN
  TECHNICIAN
  INSTRUCTOR
  STUDENT
}

enum EquipmentStatus {
  AVAILABLE
  IN_USE
  MAINTENANCE
  BROKEN
}

enum BookingStatus {
  PENDING
  APPROVED
  IN_USE
  COMPLETED
  CANCELED
  REJECTED
}

enum ReportStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  REJECTED
  PENDING
}

// ==========================================
// ĐỊNH NGHĨA CÁC BẢNG (MODELS)
// ==========================================

model User {
  id         Int        @id @default(autoincrement())
  name       String     @db.VarChar(255)
  email      String     @unique @db.VarChar(255)
  password   String     @db.VarChar(255)
  role       Role       @default(STUDENT)
  avatar_url String?    @db.VarChar(500) // Hình ảnh đại diện (Media)
  is_active  Boolean    @default(true)   // Trạng thái khóa/mở khóa tài khoản
  blacklist_reason String? @db.Text      // Lý do bị khóa tài khoản
  refresh_token String? @db.Text         // Token làm mới cấp lại Access Token
  created_at DateTime   @default(now())
  updated_at DateTime   @updatedAt

  bookings         Booking[]  // Mối quan hệ 1-N: 1 người dùng có nhiều lịch đặt
  audit_logs       AuditLog[] // Nhật ký thao tác của người dùng
  courses          Course[]   // Học phần do giảng viên quản lý
  reports          Report[]
  check_in_records CheckInRecord[]
  comments         Comment[]
  
  @@map("users")
}

model Course {
  id            Int      @id @default(autoincrement())
  code          String   @unique @db.VarChar(100)
  name          String   @db.VarChar(255)
  instructor_id Int
  created_at    DateTime @default(now())

  instructor    User     @relation(fields: [instructor_id], references: [id], onDelete: Cascade)
  bookings      Booking[]
  chemical_usages ChemicalUsage[]

  @@map("courses")
}

model Room {
  id                  Int       @id @default(autoincrement())
  name                String    @unique @db.VarChar(100)
  location            String    @db.VarChar(255)
  capacity            Int
  has_air_conditioner Boolean   @default(true)
  image_url           String?   @db.VarChar(500) // Hình ảnh phòng Lab (Media)
  created_at          DateTime  @default(now())

  equipment           Equipment[]
  bookings            Booking[]
  reports             Report[]
  check_in_records    CheckInRecord[]

  @@map("rooms")
}

model Equipment {
  id               Int             @id @default(autoincrement())
  name             String          @db.VarChar(255)
  serial_number    String          @unique @db.VarChar(100)
  status           EquipmentStatus @default(AVAILABLE)
  room_id          Int
  last_maintenance DateTime?       @db.Date
  image_url        String?         @db.VarChar(500) // Hình ảnh thiết bị (Media)
  created_at       DateTime        @default(now())
  
  // Tối ưu hóa Concurrency: Tránh đụng độ khi 2 người cùng cập nhật trạng thái thiết bị
  row_version      Int             @default(1)

  room             Room            @relation(fields: [room_id], references: [id], onDelete: Cascade)
  bookings         Booking[]
  reports          Report[]
  check_in_records CheckInRecord[]
  comments         Comment[]

  @@index([status])
  @@map("equipment")
}

model Chemical {
  id              Int             @id @default(autoincrement())
  name            String          @db.VarChar(255)
  formula         String?         @db.VarChar(100)
  quantity_stock  Float           @default(0.0)
  unit            String          @db.VarChar(20)
  expiration_date DateTime?       @db.Date // Cảnh báo hóa chất sắp hết hạn
  image_url       String?         @db.VarChar(500) // Hình ảnh hóa chất (Media)
  created_at      DateTime        @default(now())

  usages          ChemicalUsage[]

  @@map("chemicals")
}

model Booking {
  id           Int           @id @default(autoincrement())
  user_id      Int
  room_id      Int
  equipment_id Int?
  course_id    Int?
  start_time   DateTime
  end_time     DateTime
  status       BookingStatus @default(PENDING)
  purpose      String        @db.Text
  created_at   DateTime      @default(now())
  
  // Tối ưu hóa Concurrency: Phiên bản bản ghi để chặn đụng độ lịch (Optimistic Locking)
  row_version  Int           @default(1)

  user            User            @relation(fields: [user_id], references: [id], onDelete: Cascade)
  room            Room            @relation(fields: [room_id], references: [id], onDelete: Cascade)
  equipment       Equipment?      @relation(fields: [equipment_id], references: [id], onDelete: SetNull)
  course          Course?         @relation(fields: [course_id], references: [id], onDelete: SetNull)
  chemical_usages ChemicalUsage[]
  check_in_records CheckInRecord[]
  comments        Comment[]

  // Tạo chỉ mục Index giống hệt SQL để tăng tốc truy vấn kiểm tra trùng lịch
  @@index([room_id, start_time, end_time])
  @@index([equipment_id, start_time, end_time])
  @@index([status])
  @@map("bookings")
}

model ChemicalUsage {
  id            Int      @id @default(autoincrement())
  booking_id    Int
  chemical_id   Int
  course_id     Int?
  quantity_used Float
  used_at       DateTime @default(now())

  booking       Booking  @relation(fields: [booking_id], references: [id], onDelete: Cascade)
  chemical      Chemical @relation(fields: [chemical_id], references: [id], onDelete: Cascade)
  course        Course?  @relation(fields: [course_id], references: [id], onDelete: SetNull)

  @@map("chemical_usage")
}

// Bảng lưu vết hệ thống (Bổ sung theo yêu cầu kiến trúc an toàn dữ liệu)
model AuditLog {
  id         Int      @id @default(autoincrement())
  action     String   @db.VarChar(255) // Ví dụ: 'CREATE_BOOKING', 'DELETE_EQUIPMENT'
  table_name String   @db.VarChar(100)
  record_id  Int
  user_id    Int?
  details    String?  @db.Text
  timestamp  DateTime @default(now())

  user       User?    @relation(fields: [user_id], references: [id], onDelete: SetNull)

  @@map("audit_logs")
}

model Report {
  id           Int          @id @default(autoincrement())
  user_id      Int
  equipment_id Int?
  room_id      Int?
  title        String       @db.VarChar(255)
  description  String       @db.Text
  status       ReportStatus @default(OPEN)
  image_url    String?      @db.VarChar(500)
  created_at   DateTime     @default(now())

  user         User         @relation(fields: [user_id], references: [id], onDelete: Cascade)
  equipment    Equipment?   @relation(fields: [equipment_id], references: [id], onDelete: SetNull)
  room         Room?        @relation(fields: [room_id], references: [id], onDelete: SetNull)
  comments     Comment[]

  @@map("reports")
}

model CheckInRecord {
  id           Int       @id @default(autoincrement())
  booking_id   Int?
  user_id      Int
  equipment_id Int?
  room_id      Int?
  check_in     DateTime  @default(now())
  check_out    DateTime?
  status       String    @default("ACTIVE") @db.VarChar(50)

  user         User      @relation(fields: [user_id], references: [id], onDelete: Cascade)
  booking      Booking?  @relation(fields: [booking_id], references: [id], onDelete: SetNull)
  equipment    Equipment? @relation(fields: [equipment_id], references: [id], onDelete: SetNull)
  room         Room?     @relation(fields: [room_id], references: [id], onDelete: SetNull)

  @@map("check_in_records")
}

model Comment {
  id           Int       @id @default(autoincrement())
  content      String    @db.Text
  user_id      Int
  report_id    Int?
  booking_id   Int?
  equipment_id Int?
  parent_id    Int?
  created_at   DateTime  @default(now())
  updated_at   DateTime  @updatedAt

  user         User      @relation(fields: [user_id], references: [id], onDelete: Cascade)
  report       Report?   @relation(fields: [report_id], references: [id], onDelete: Cascade)
  booking      Booking?  @relation(fields: [booking_id], references: [id], onDelete: Cascade)
  equipment    Equipment? @relation(fields: [equipment_id], references: [id], onDelete: Cascade)
  
  parent       Comment?  @relation("CommentReplies", fields: [parent_id], references: [id], onDelete: Cascade)
  replies      Comment[] @relation("CommentReplies")

  @@map("comments")
}

model SystemSetting {
  id          Int      @id @default(autoincrement())
  key         String   @unique @db.VarChar(100)
  value       String   @db.Text
  description String?  @db.VarChar(255)
  category    String   @default("GENERAL") @db.VarChar(50)
  updated_at  DateTime @updatedAt

  @@map("system_settings")
}
