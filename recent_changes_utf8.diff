@@ -0,0 +1,76 @@
+import { Injectable, Logger } from '@nestjs/common';
+import { Cron, CronExpression } from '@nestjs/schedule';
+import { PrismaService } from '../prisma/prisma.service';
+
+@Injectable()
+export class TasksService {
+  private readonly logger = new Logger(TasksService.name);
+
+  constructor(private readonly prisma: PrismaService) {}
+
+  // Chß║íy mß╗ùi giß╗¥ mß╗Öt lß║ºn ─æß╗â kiß╗âm tra v├á hß╗ºy c├íc booking PENDING qu├í 24h
+  @Cron(CronExpression.EVERY_HOUR)
+  async handleCronCancelPendingBookings() {
+    this.logger.debug('─Éang chß║íy cronjob: Tß╗▒ ─æß╗Öng hß╗ºy c├íc lß╗ïch ─æß║╖t PENDING qu├í 24h...');
+    
+    const twentyFourHoursAgo = new Date();
+    twentyFourHoursAgo.setHours(twentyFourHoursAgo.getHours() - 24);
+
+    try {
+      const result = await this.prisma.booking.updateMany({
+        where: {
+          status: 'PENDING',
+          created_at: { lt: twentyFourHoursAgo }
+        },
+        data: {
+          status: 'CANCELED',
+          // Note: updateMany does not support row_version increment per row easily without raw query, 
+          // but since it's an automated background task resolving dangling state, it's acceptable here.
+        }
+      });
+      
+      if (result.count > 0) {
+        this.logger.log(`─É├ú tß╗▒ ─æß╗Öng hß╗ºy ${result.count} ─æ╞ín ─æß║╖t lß╗ïch qu├í 24h ch╞░a duyß╗çt.`);
+      }
+    } catch (error) {
+      this.logger.error('Lß╗ùi khi chß║íy cronjob hß╗ºy ─æ╞ín:', error);
+    }
+  }
+
+  // Chß║íy mß╗ùi 30 ph├║t ─æß╗â tß╗▒ ─æß╗Öng hß╗ºy c├íc lß╗ïch IN_USE nß║┐u ─æ├ú qu├í thß╗¥i gian kß║┐t th├║c m├á kh├┤ng check-out
+  // Hoß║╖c tß╗▒ ─æß╗Öng hß╗ºy c├íc lß╗ïch APPROVED nß║┐u ─æ├ú qua thß╗¥i gian bß║»t ─æß║ºu m├á kh├┤ng check-in
+  @Cron('0 */30 * * * *')
+  async handleCronCleanUpExpiredBookings() {
+    this.logger.debug('─Éang chß║íy cronjob: Dß╗ìn dß║╣p c├íc lß╗ïch APPROVED/IN_USE ─æ├ú qu├í hß║ín...');
+    const now = new Date();
+
+    try {
+      // 1. Hß╗ºy c├íc ─æ╞ín APPROVED nh╞░ng kh├┤ng ─æß║┐n check-in (qu├í hß║ín 30 ph├║t sau giß╗¥ bß║»t ─æß║ºu)
+      const thirtyMinutesAgo = new Date();
+      thirtyMinutesAgo.setMinutes(thirtyMinutesAgo.getMinutes() - 30);
+      
+      const noShows = await this.prisma.booking.updateMany({
+        where: {
+          status: 'APPROVED',
+          start_time: { lt: thirtyMinutesAgo }
+        },
+        data: { status: 'CANCELED' }
+      });
+
+      // 2. Chuyß╗ân IN_USE th├ánh COMPLETED nß║┐u ─æ├ú qua thß╗¥i gian end_time (Giß║ú sß╗¡ tß╗▒ ─æß╗Öng check-out)
+      const autoCompleted = await this.prisma.booking.updateMany({
+        where: {
+          status: 'IN_USE',
+          end_time: { lt: now }
+        },
+        data: { status: 'COMPLETED' }
+      });
+
+      if (noShows.count > 0 || autoCompleted.count > 0) {
+        this.logger.log(`─É├ú hß╗ºy ${noShows.count} ─æ╞ín (No-show), Tß╗▒ ─æß╗Öng ho├án th├ánh ${autoCompleted.count} ─æ╞ín.`);
+      }
+    } catch (error) {
+      this.logger.error('Lß╗ùi khi chß║íy cronjob dß╗ìn dß║╣p:', error);
+    }
+  }
+}
